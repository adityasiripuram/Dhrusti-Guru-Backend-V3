# Database
# Use DATABASE_URL for hosted Postgres providers like Neon.
DATABASE_URL=
DB_SSL=false
DB_SYNCHRONIZE=true

# Use these for local/Docker Postgres when DATABASE_URL is empty.
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=



JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=

# AWS Rekognition (optional)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REKOGNITION_COLLECTION=

# App
PORT=

# Seed defaults
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_BRANCH_NAME=

# Feature flags
ENABLE_AWS_REKOGNITION=
